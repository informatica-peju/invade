# Inventory file path (JSON) / Caminho do inventário (JSON)
INVENTORY_FILE=configs/inventory.json

# Optional defaults used when a device does not define its own values
# Defaults opcionais usados quando o dispositivo não define valores próprios
ROUTER_USER=admin
ROUTER_PASSWORD=
ROUTER_PORT=22

# SSH timeout in seconds / Timeout SSH em segundos
SSH_TIMEOUT=20
